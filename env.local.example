# Shared across local development and Vercel Preview

# Supabase preview/dev project
NEXT_PUBLIC_SUPABASE_URL=https://<preview-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<preview-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<preview-service-role-key>
DATABASE_URL=postgresql://postgres:<password>@<preview-pooler-host>:5432/postgres
DATABASE_DIRECT_URL=postgresql://postgres:<password>@db.<preview-project>.supabase.co:5432/postgres
DATABASE_POOLER_URL=postgresql://postgres.<preview-project>:<password>@<preview-pooler-host>:5432/postgres
SUPABASE_STORAGE_BUCKET=boq-generator-dev

# Credit top-up payments (manual)
TOPUP_WHATSAPP_NUMBER=+260...
TOPUP_ECOCASH_NUMBER=+260...
TOPUP_BANK_DETAILS="Bank: XYZ · Account: 1234567 · Branch: Lusaka"

# Shared external services
GEMINI_API_KEY=<google-ai-key>
RESEND_API_KEY=<resend-key>
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=https://...@....ingest.sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
UPSTASH_REDIS_REST_URL=https://<name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Inngest background jobs
INNGEST_EVENT_KEY=<from-inngest-dashboard>
INNGEST_SIGNING_KEY=<from-inngest-dashboard>

# Optional model overrides
GEMINI_MODEL_PRIMARY=gemini-2.5-pro
GEMINI_MODEL_FALLBACK=gemini-2.5-flash
