# BOQ Generator — Environment Variables
# Copy to .env.local and fill in your values. Never commit .env.local.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=boq-generator-dev

# --- AI providers ---
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email — Resend ---
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=BOQ Generator <boq-support@aakitech.com>

# --- Contact email (landing page service offer CTAs) ---
# Production value: software@aakitech.com (set in Vercel)
NEXT_PUBLIC_CONTACT_EMAIL=software@aakitech.com

# --- Admin access (comma-separated, guards /admin and /api/admin routes) ---
MANUAL_PAYMENT_APPROVER_EMAILS=brightontandabantu@gmail.com,software@aakitech.com

# --- Inngest (production pipeline; run inngest-cli locally instead) ---
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# --- Stripe (optional locally) ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Manual payments (WhatsApp / MoMo / bank) ---
TOPUP_WHATSAPP_NUMBER=+260XXXXXXXXX
TOPUP_MOMO_NUMBER=+260XXXXXXXXX
TOPUP_BANK_DETAILS=Bank name, Account number, Branch

# --- Analytics (optional locally) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Sentry (optional locally) ---
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# --- Upstash Redis rate limiting (optional locally) ---
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# --- Force Inngest in dev (omit to run jobs inline) ---
# BOQ_BACKGROUND_MODE=inngest
