# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# Database (used by migration scripts and pg pool)
DATABASE_URL=
DATABASE_DIRECT_URL=
DATABASE_POOLER_URL=

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Optional: override default model names
GEMINI_MODEL_PRIMARY=gemini-2.5-pro
GEMINI_MODEL_FALLBACK=gemini-2.5-flash
GEMINI_RATE_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_RATE_MODEL_FALLBACK=
GEMINI_SOW_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_SOW_MODEL_FALLBACK=

# Optional: OpenAI as primary (Gemini becomes fallback when set)
OPENAI_API_KEY=

# ── Top-up (WhatsApp/MoMo manual payment flow) ────────────────────────────────
TOPUP_WHATSAPP_NUMBER=
TOPUP_MOMO_NUMBER=
TOPUP_BANK_DETAILS=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Rate limiting (optional — disables gracefully if absent) ──────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Inngest ───────────────────────────────────────────────────────────────────
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=
